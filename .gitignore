# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
# --- Bun ---
.bun/
/bun.lockb.bak # 備份檔可以忽略

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- Go Backend ---
# 編譯出的執行檔 (Binary)
main
main.exe
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# --- Project Specific (PDF & ICS) ---
# 不要把測試用的校曆 PDF 傳上去
public/uploads/*.pdf
*.pdf

# 不要把產出的行事曆檔案傳上去
*.ics

# --- Editor / IDE ---
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (GoLand / WebStorm)
.idea/

# --- OS Specific ---
Thumbs.db
db.json